<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add Note</title>
</head>
<body>
  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css"
    rel="stylesheet"
>
<h1 class="mb-4">
    Add New Note
</h1>
<br>
<% if(error){ %>

    <div class="alert alert-danger">
        <%= error %>
    </div>

<% } %>
<br>
<form action="/user/add" method="POST">

    <div class="mb-3">   

        <label class="form-label">
            Title
        </label>

        <input
            type="text"
            name="title"
            class="form-control"
            placeholder="Enter Note Title"
            required
        >

    </div>

    <div class="mb-3">

        <label class="form-label">
            Content
        </label>

        <textarea
            name="content"
            class="form-control"
            rows="5"
            placeholder="Write your note here..."
            required
        ></textarea>

    </div>

    <div class="mb-3">

        <label class="form-label">
            Tags
        </label>

        <input
            type="text"
            name="tag"
            class="form-control"
            placeholder="javascript,nodejs,mongodb"
        >

    </div>

    <button
        type="submit"
        class="btn btn-success"
    >
        Save Note
    </button>

    <a
        href="/user/home"
        class="btn btn-secondary"
    >
        Cancel
    </a>

</form>

</body>
</html>