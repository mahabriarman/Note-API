<!DOCTYPE html>
<html>
<head>
    <title>Edit Note</title>
</head>
<body>

<h1>Edit Note</h1>

<form
    action="/user/edit/<%= note._id %>"
    method="POST"
>

    <input
        type="text"
        name="title"
        value="<%= note.title %>"
    >

    <br><br>

    <textarea
        name="content"
        rows="5"
        cols="30"
    ><%= note.content %></textarea>

    <br><br>

    <button type="submit">
        Update Note
    </button>

</form>

</body>
</html>
